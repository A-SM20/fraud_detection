# Environment Configuration
# Copy this to .env and fill in values

# PostgreSQL
POSTGRES_USER=fraud_user
POSTGRES_PASSWORD=CHANGE_ME_IN_PRODUCTION
POSTGRES_DB=fraud_pipeline
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# API Server
API_PORT=3000
NODE_ENV=development

# Scoring Worker
SCORING_THRESHOLD=0.35
MODEL_VERSION=v1.0.0
WORKER_CONCURRENCY=1

# Dashboard
DASHBOARD_PORT=3001
VITE_API_URL=http://api:3000

# Authentication
# Set to 'true' to skip all auth checks during development
SKIP_AUTH=true
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_256_BIT_STRING
JWT_EXPIRY=8h
# Comma-separated API keys for machine-to-machine ingestion
API_KEYS=dev-api-key-1,dev-api-key-2

# CORS (set specific origin in production)
CORS_ORIGIN=*

# Logging
LOG_LEVEL=info
